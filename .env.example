# Firebase（本番同期に必要）。未設定ならローカルモード（同一ブラウザ内同期・開発用）で動く。
# Firebase コンソール → プロジェクトの設定 → 全般 → ウェブアプリ から取得
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_PROJECT_ID=

# 管理者ログイン用に Firebase Authentication に作ったユーザーのメールアドレス。
# 管理画面の「合言葉」はこのユーザーのパスワード。
VITE_FIREBASE_ADMIN_EMAIL=admin@classmatch.local

# ローカルモード時のみ使う合言葉（Firebase 設定時は無視される）
VITE_ADMIN_PASSCODE=classmatch

# ライブ映像（アプリ内配信）の中継サーバー(TURN)。
# 同一Wi-Fi・多くの環境では未設定でも直接つながる（STUNのみ）。
# 学校ネットワークが端末どうしの直接通信を遮断していて映像が届かない場合のみ設定する。
VITE_TURN_URL=
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=
